---
import { Code } from "@bambi/ui";
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Code">
  <h1 class="mb-2 text-3xl font-bold">Code</h1>
  <p class="mb-10 text-muted-foreground">Thin wrapper that renders an inline <code class="rounded bg-muted px-1 text-sm">&lt;code&gt;</code> element.</p>

  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Preview</h2>
  <div class="flex flex-col gap-3 rounded-lg border border-border bg-secondary p-8 text-sm">
    <p>Run <Code>pnpm install</Code> to get started.</p>
    <p>Import from <Code>@bambi/ui</Code> in your components.</p>
  </div>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Usage</h2>
  <pre class="overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`import { Code } from "@bambi/ui";

<p>Run <Code>pnpm install</Code> to get started.</p>`}</pre>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Props</h2>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Prop</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Type</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Required</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr><td class="border-b border-border/50 px-4 py-2"><code class="rounded bg-muted px-1 text-xs">children</code></td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">ReactNode</code></td><td class="border-b border-border/50 px-4 py-2">✓</td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground">Code content.</td></tr>
      <tr><td class="px-4 py-2"><code class="rounded bg-muted px-1 text-xs">className</code></td><td class="px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">string</code></td><td class="px-4 py-2">—</td><td class="px-4 py-2 text-muted-foreground">Additional Tailwind classes or custom CSS class.</td></tr>
    </tbody>
  </table>
</Layout>
