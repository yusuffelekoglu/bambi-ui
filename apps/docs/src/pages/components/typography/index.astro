---
import { marked } from "marked";
import { Heading, Text } from "@bambi-ui/typography";
import Layout from "../../../layouts/Layout.astro";
import readme from "../../../../../../packages/typography/README.md?raw";

const readmeHtml = await marked(readme);
---

<Layout title="Typography" description="Typography components for bambi-ui — Heading (h1–h6) and Text (body, lead, small, muted, label). Fully accessible and WCAG 2.2 AA compliant." keywords="bambi-ui typography, react heading component, react text component, accessible typography, heading hierarchy, wcag typography, typescript">
  <h1 class="mb-2 text-3xl font-bold">Typography</h1>
  <p class="mb-10 text-muted-foreground">
    Semantic heading and text components with consistent scale and theming.
  </p>

  <!-- Headings -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Heading</h2>
  <div class="mb-2 flex flex-col gap-3 rounded-lg border border-border bg-secondary p-8">
    <Heading level={1} client:load>Heading 1</Heading>
    <Heading level={2} client:load>Heading 2</Heading>
    <Heading level={3} client:load>Heading 3</Heading>
    <Heading level={4} client:load>Heading 4</Heading>
    <Heading level={5} client:load>Heading 5</Heading>
    <Heading level={6} client:load>Heading 6</Heading>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Heading level={1}>Heading 1</Heading>
<Heading level={2}>Heading 2</Heading>
<Heading level={3}>Heading 3</Heading>
<Heading level={4}>Heading 4</Heading>
<Heading level={5}>Heading 5</Heading>
<Heading level={6}>Heading 6</Heading>`}</pre>

  <!-- Text variants -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Text</h2>
  <div class="mb-2 flex flex-col gap-4 rounded-lg border border-border bg-secondary p-8">
    <Text client:load>Body — The quick brown fox jumps over the lazy dog.</Text>
    <Text variant="lead" client:load>Lead — A larger introductory paragraph that sets the scene.</Text>
    <Text variant="small" client:load>Small — Fine print or secondary information.</Text>
    <Text variant="muted" client:load>Muted — Subdued helper or descriptive text.</Text>
    <Text variant="label" as="span" client:load>Label</Text>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Text>Body text</Text>
<Text variant="lead">Lead text</Text>
<Text variant="small">Small text</Text>
<Text variant="muted">Muted text</Text>
<Text variant="label" as="span">Label</Text>`}</pre>

  <!-- Decoupled level and element -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Decoupled style and element</h2>
  <div class="mb-2 flex flex-col gap-2 rounded-lg border border-border bg-secondary p-8">
    <Heading level={1} as="h2" client:load>h2 in DOM, styled as h1</Heading>
    <Heading level={3} as="h2" client:load>h2 in DOM, styled as h3</Heading>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`{/* h2 in the DOM, styled as h1 */}
<Heading level={1} as="h2">Section title</Heading>

{/* h2 in the DOM, styled as h3 */}
<Heading level={3} as="h2">Subsection</Heading>`}</pre>

  <!-- as prop on Text -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Custom element</h2>
  <div class="mb-2 flex flex-col gap-2 rounded-lg border border-border bg-secondary p-8">
    <Text variant="muted" as="div" client:load>div rendered as muted text</Text>
    <Text variant="label" as="span" client:load>span rendered as label</Text>
    <Text variant="small" as="strong" client:load>strong rendered as small</Text>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Text variant="muted" as="div">div rendered as muted text</Text>
<Text variant="label" as="span">span rendered as label</Text>
<Text variant="small" as="strong">strong rendered as small</Text>`}</pre>

  <!-- README -->
  <hr class="border-border" />
  <div class="prose mt-8">
    <Fragment set:html={readmeHtml} />
  </div>
</Layout>
