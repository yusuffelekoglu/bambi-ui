---
import { marked } from "marked";
import { Button } from "@bambi-ui/button";
import Layout from "../../../layouts/Layout.astro";
import readme from "../../../../../../packages/button/README.md?raw";

const readmeHtml = await marked(readme);
---

<Layout title="Button">
  <h1 class="mb-2 text-3xl font-bold">Button</h1>
  <p class="mb-10 text-muted-foreground">
    Accessible, themeable button with keyboard focus ring support.
  </p>

  <!-- Variants -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Variants</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button client:load>Primary</Button>
    <Button variant="secondary" client:load>Secondary</Button>
    <Button variant="ghost" client:load>Ghost</Button>
    <Button variant="destructive" client:load>Destructive</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button>Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="destructive">Destructive</Button>`}</pre>

  <!-- Sizes -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Sizes</h2>
  <div class="mb-2 flex flex-wrap items-end gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button size="sm" client:load>Small</Button>
    <Button size="md" client:load>Medium</Button>
    <Button size="lg" client:load>Large</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button size="sm">Small</Button>
<Button size="md">Medium</Button>
<Button size="lg">Large</Button>`}</pre>

  <!-- Disabled -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Disabled</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button disabled client:load>Primary</Button>
    <Button variant="secondary" disabled client:load>Secondary</Button>
    <Button variant="ghost" disabled client:load>Ghost</Button>
    <Button variant="destructive" disabled client:load>Destructive</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button disabled>Primary</Button>`}</pre>

  <!-- Combinations -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">All combinations</h2>
  <div class="mb-10 overflow-x-auto rounded-lg border border-border bg-secondary p-8">
    <table class="w-full text-sm">
      <thead>
        <tr>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground"></th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">sm</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">md</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">lg</th>
        </tr>
      </thead>
      <tbody class="[&_td]:pb-3 [&_td]:pr-6">
        <tr>
          <td class="text-xs text-muted-foreground">primary</td>
          <td><Button size="sm" client:load>Label</Button></td>
          <td><Button size="md" client:load>Label</Button></td>
          <td><Button size="lg" client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">secondary</td>
          <td><Button variant="secondary" size="sm" client:load>Label</Button></td>
          <td><Button variant="secondary" size="md" client:load>Label</Button></td>
          <td><Button variant="secondary" size="lg" client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">ghost</td>
          <td><Button variant="ghost" size="sm" client:load>Label</Button></td>
          <td><Button variant="ghost" size="md" client:load>Label</Button></td>
          <td><Button variant="ghost" size="lg" client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">destructive</td>
          <td><Button variant="destructive" size="sm" client:load>Label</Button></td>
          <td><Button variant="destructive" size="md" client:load>Label</Button></td>
          <td><Button variant="destructive" size="lg" client:load>Label</Button></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- README -->
  <hr class="border-border" />
  <div class="prose mt-8">
    <Fragment set:html={readmeHtml} />
  </div>
</Layout>
