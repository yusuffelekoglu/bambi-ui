---
import { Button } from "@bambi-ui/button";
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Button">
  <h1 class="mb-2 text-3xl font-bold">Button</h1>
  <p class="mb-10 text-muted-foreground">Client-side button that triggers an alert with the app name.</p>

  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Preview</h2>
  <div class="flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button appName="docs" client:load>Click me</Button>
    <Button appName="docs" className="opacity-50 cursor-not-allowed" client:load>Disabled look</Button>
  </div>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Usage</h2>
  <pre class="overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`import { Button } from "@bambi-ui/button";

<Button appName="web">Click me</Button>`}</pre>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Props</h2>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Prop</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Type</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Required</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr><td class="border-b border-border/50 px-4 py-2"><code class="rounded bg-muted px-1 text-xs">appName</code></td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">string</code></td><td class="border-b border-border/50 px-4 py-2">✓</td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground">App name shown in the alert message.</td></tr>
      <tr><td class="border-b border-border/50 px-4 py-2"><code class="rounded bg-muted px-1 text-xs">children</code></td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">ReactNode</code></td><td class="border-b border-border/50 px-4 py-2">✓</td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground">Button content.</td></tr>
      <tr><td class="px-4 py-2"><code class="rounded bg-muted px-1 text-xs">className</code></td><td class="px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">string</code></td><td class="px-4 py-2">—</td><td class="px-4 py-2 text-muted-foreground">Additional Tailwind classes or custom CSS class.</td></tr>
    </tbody>
  </table>
</Layout>
