---
import { marked } from "marked";
import { Button } from "@bambi-ui/button";
import Layout from "../../../layouts/Layout.astro";
import readme from "../../../../../../packages/button/README.md?raw";

const readmeHtml = await marked(readme);
---

<Layout title="Button">
  <h1 class="mb-2 text-3xl font-bold">Button</h1>
  <p class="mb-10 text-muted-foreground">
    Accessible, themeable button with keyboard focus ring support.
  </p>

  <!-- Variants -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Variants</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button client:load>Primary</Button>
    <Button variant="secondary" client:load>Secondary</Button>
    <Button variant="outline" client:load>Outline</Button>
    <Button variant="ghost" client:load>Ghost</Button>
    <Button variant="link" client:load>Link</Button>
    <Button variant="destructive" client:load>Destructive</Button>
    <Button variant="success" client:load>Success</Button>
    <Button variant="warning" client:load>Warning</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button>Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="outline">Outline</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="link">Link</Button>
<Button variant="destructive">Destructive</Button>
<Button variant="success">Success</Button>
<Button variant="warning">Warning</Button>`}</pre>

  <!-- Sizes -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Sizes</h2>
  <div class="mb-2 flex flex-wrap items-end gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button size="sm" client:load>Small</Button>
    <Button size="md" client:load>Medium</Button>
    <Button size="lg" client:load>Large</Button>
    <Button size="icon" aria-label="Add" client:load>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button size="sm">Small</Button>
<Button size="md">Medium</Button>
<Button size="lg">Large</Button>
<Button size="icon" aria-label="Add"><PlusIcon /></Button>`}</pre>

  <!-- With icon -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">With icon</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button client:load>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Save changes
    </Button>
    <Button variant="outline" client:load>
      Continue
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </Button>
    <Button variant="destructive" client:load>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      Delete
    </Button>
    <Button variant="ghost" client:load>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" x2="3" y2="3" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share
    </Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button>
  <SaveIcon aria-hidden="true" />
  Save changes
</Button>

<Button variant="outline">
  Continue
  <ArrowRightIcon aria-hidden="true" />
</Button>`}</pre>

  <!-- Loading -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Loading</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button loading client:load>Saving…</Button>
    <Button variant="secondary" loading client:load>Loading…</Button>
    <Button variant="outline" loading client:load>Loading…</Button>
    <Button variant="destructive" loading client:load>Deleting…</Button>
    <Button variant="success" loading client:load>Submitting…</Button>
    <Button size="icon" loading aria-label="Loading" client:load>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button loading>Saving…</Button>
<Button variant="destructive" loading>Deleting…</Button>`}</pre>

  <!-- Full width -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Full width</h2>
  <div class="mb-2 flex flex-col gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button className="w-full" client:load>Primary</Button>
    <Button variant="outline" className="w-full" client:load>Outline</Button>
    <Button variant="secondary" className="w-full" loading client:load>Loading</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button className="w-full">Primary</Button>`}</pre>

  <!-- Disabled -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Disabled</h2>
  <div class="mb-2 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-secondary p-8">
    <Button disabled client:load>Primary</Button>
    <Button variant="secondary" disabled client:load>Secondary</Button>
    <Button variant="outline" disabled client:load>Outline</Button>
    <Button variant="ghost" disabled client:load>Ghost</Button>
    <Button variant="link" disabled client:load>Link</Button>
    <Button variant="destructive" disabled client:load>Destructive</Button>
    <Button variant="success" disabled client:load>Success</Button>
    <Button variant="warning" disabled client:load>Warning</Button>
  </div>
  <pre class="mb-10 overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`<Button disabled>Primary</Button>`}</pre>

  <!-- Combinations -->
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">All combinations</h2>
  <div class="mb-10 overflow-x-auto rounded-lg border border-border bg-secondary p-8">
    <table class="w-full text-sm">
      <thead>
        <tr>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground"></th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">sm</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">md</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">lg</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">icon</th>
          <th class="pb-4 pr-6 text-left text-xs font-medium text-muted-foreground">loading</th>
        </tr>
      </thead>
      <tbody class="[&_td]:pb-3 [&_td]:pr-6">
        <tr>
          <td class="text-xs text-muted-foreground">primary</td>
          <td><Button size="sm" client:load>Label</Button></td>
          <td><Button size="md" client:load>Label</Button></td>
          <td><Button size="lg" client:load>Label</Button></td>
          <td><Button size="icon" aria-label="primary icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">secondary</td>
          <td><Button variant="secondary" size="sm" client:load>Label</Button></td>
          <td><Button variant="secondary" size="md" client:load>Label</Button></td>
          <td><Button variant="secondary" size="lg" client:load>Label</Button></td>
          <td><Button variant="secondary" size="icon" aria-label="secondary icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="secondary" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">outline</td>
          <td><Button variant="outline" size="sm" client:load>Label</Button></td>
          <td><Button variant="outline" size="md" client:load>Label</Button></td>
          <td><Button variant="outline" size="lg" client:load>Label</Button></td>
          <td><Button variant="outline" size="icon" aria-label="outline icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="outline" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">ghost</td>
          <td><Button variant="ghost" size="sm" client:load>Label</Button></td>
          <td><Button variant="ghost" size="md" client:load>Label</Button></td>
          <td><Button variant="ghost" size="lg" client:load>Label</Button></td>
          <td><Button variant="ghost" size="icon" aria-label="ghost icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="ghost" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">link</td>
          <td><Button variant="link" size="sm" client:load>Label</Button></td>
          <td><Button variant="link" size="md" client:load>Label</Button></td>
          <td><Button variant="link" size="lg" client:load>Label</Button></td>
          <td><Button variant="link" size="icon" aria-label="link icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="link" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">destructive</td>
          <td><Button variant="destructive" size="sm" client:load>Label</Button></td>
          <td><Button variant="destructive" size="md" client:load>Label</Button></td>
          <td><Button variant="destructive" size="lg" client:load>Label</Button></td>
          <td><Button variant="destructive" size="icon" aria-label="destructive icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="destructive" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">success</td>
          <td><Button variant="success" size="sm" client:load>Label</Button></td>
          <td><Button variant="success" size="md" client:load>Label</Button></td>
          <td><Button variant="success" size="lg" client:load>Label</Button></td>
          <td><Button variant="success" size="icon" aria-label="success icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="success" loading client:load>Label</Button></td>
        </tr>
        <tr>
          <td class="text-xs text-muted-foreground">warning</td>
          <td><Button variant="warning" size="sm" client:load>Label</Button></td>
          <td><Button variant="warning" size="md" client:load>Label</Button></td>
          <td><Button variant="warning" size="lg" client:load>Label</Button></td>
          <td><Button variant="warning" size="icon" aria-label="warning icon" client:load><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></Button></td>
          <td><Button variant="warning" loading client:load>Label</Button></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- README -->
  <hr class="border-border" />
  <div class="prose mt-8">
    <Fragment set:html={readmeHtml} />
  </div>
</Layout>
