---
import { ColorPicker } from "@bambi/ui";
import { ColorPickerDemo } from "../../../components/ColorPickerDemo";
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="ColorPicker">
  <h1 class="mb-2 text-3xl font-bold">ColorPicker</h1>
  <p class="mb-10 text-muted-foreground">
    Controlled color-picker component. Clicking the swatch opens the browser's native color dialog;
    the hex field accepts manual input. Both inputs stay in sync.
  </p>

  <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Preview</h2>
  <div class="flex flex-col gap-4 rounded-lg border border-border bg-secondary p-8">
    <ColorPickerDemo client:load />
    <div class="flex flex-wrap items-center gap-6 text-xs text-muted-foreground">
      <span class="flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-primary"></span> Primary</span>
      <span class="flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-destructive"></span> Destructive</span>
      <span class="flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-muted"></span> Muted</span>
    </div>
    <p class="text-xs text-muted-foreground">
      The demo above is interactive. For token-level editing, open the <a href="/theme" class="text-primary hover:underline">Theme Builder</a>.
    </p>
  </div>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Usage</h2>
  <pre class="overflow-x-auto rounded-md border border-border bg-muted px-5 py-4 text-xs text-foreground">{`import { ColorPicker } from "@bambi/ui";
import { useState } from "react";

function Example() {
  const [color, setColor] = useState("#3b72e8");

  return <ColorPicker value={color} onChange={setColor} />;
}`}</pre>

  <h2 class="mb-3 mt-10 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Props</h2>
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Prop</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Type</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Required</th>
        <th class="border-b border-border px-4 py-2 text-left font-medium text-muted-foreground">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr><td class="border-b border-border/50 px-4 py-2"><code class="rounded bg-muted px-1 text-xs">value</code></td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">string</code></td><td class="border-b border-border/50 px-4 py-2">✓</td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground">Current hex color value (<code class="rounded bg-muted px-1 text-xs">#rrggbb</code>).</td></tr>
      <tr><td class="border-b border-border/50 px-4 py-2"><code class="rounded bg-muted px-1 text-xs">onChange</code></td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">(value: string) =&gt; void</code></td><td class="border-b border-border/50 px-4 py-2">✓</td><td class="border-b border-border/50 px-4 py-2 text-muted-foreground">Called whenever the color changes.</td></tr>
      <tr><td class="px-4 py-2"><code class="rounded bg-muted px-1 text-xs">className</code></td><td class="px-4 py-2 text-muted-foreground"><code class="rounded bg-muted px-1 text-xs">string</code></td><td class="px-4 py-2">—</td><td class="px-4 py-2 text-muted-foreground">Additional Tailwind classes.</td></tr>
    </tbody>
  </table>
</Layout>
