---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — @bambi/ui</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #0f0f0f; color: #ededed; min-height: 100vh; display: flex; }
      nav { width: 220px; padding: 2rem 1.5rem; border-right: 1px solid #222; flex-shrink: 0; }
      nav a { display: block; font-size: 0.875rem; color: #888; text-decoration: none; padding: 0.375rem 0; }
      nav a:hover, nav a.active { color: #ededed; }
      nav .logo { font-weight: 700; font-size: 1rem; color: #ededed; margin-bottom: 2rem; display: block; text-decoration: none; }
      main { flex: 1; padding: 3rem 4rem; max-width: 900px; }
      h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
      .subtitle { color: #888; margin-bottom: 3rem; }
      h2 { font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin: 2.5rem 0 1rem; }
      .preview { background: #1a1a1a; border: 1px solid #222; border-radius: 8px; padding: 2rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
      pre { background: #111; border: 1px solid #222; border-radius: 6px; padding: 1.25rem; font-size: 0.8rem; overflow-x: auto; margin-top: 1rem; color: #a8b1c0; }
      table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
      th { text-align: left; padding: 0.5rem 1rem; border-bottom: 1px solid #222; color: #888; font-weight: 500; }
      td { padding: 0.5rem 1rem; border-bottom: 1px solid #161616; }
      td code { background: #1a1a1a; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.8rem; }
    </style>
  </head>
  <body>
    <nav>
      <a class="logo" href="/">@bambi/ui</a>
      <a href="/components/button" class={Astro.url.pathname.includes("button") ? "active" : ""}>Button</a>
      <a href="/components/card" class={Astro.url.pathname.includes("card") ? "active" : ""}>Card</a>
      <a href="/components/code" class={Astro.url.pathname.includes("code") ? "active" : ""}>Code</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
