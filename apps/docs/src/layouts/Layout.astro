---
import "../styles/globals.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "bambi-ui component documentation" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — bambi-ui</title>
  </head>
  <body class="bg-surface-0 text-text-primary font-sans antialiased">
    <div class="min-h-screen flex">
      <!-- Sidebar -->
      <aside class="w-60 shrink-0 border-r border-surface-border bg-surface-1 px-4 py-6 flex flex-col gap-1">
        <a href="/" class="flex items-center gap-2 px-2 mb-6">
          <span class="text-brand-600 font-bold text-lg tracking-tight">bambi-ui</span>
          <span class="text-xs text-text-tertiary bg-surface-2 border border-surface-border rounded px-1.5 py-0.5">v0.1</span>
        </a>

        <p class="text-xs font-semibold uppercase tracking-widest text-text-tertiary px-2 mb-1">Core</p>
        <a href="/components/button" class="text-sm text-text-secondary hover:text-text-primary hover:bg-surface-2 rounded-md px-2 py-1.5 transition-colors">
          Button
        </a>

        <p class="text-xs font-semibold uppercase tracking-widest text-text-tertiary px-2 mb-1 mt-4">Resources</p>
        <a href="https://storybook.bambi-ui.dev" class="text-sm text-text-secondary hover:text-text-primary hover:bg-surface-2 rounded-md px-2 py-1.5 transition-colors">
          Storybook ↗
        </a>
      </aside>

      <!-- Content -->
      <main class="flex-1 overflow-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
