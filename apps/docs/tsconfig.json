{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strictNullChecks": true
  },
  "include": ["src", ".astro"],
  "exclude": ["node_modules", "dist"]
}
