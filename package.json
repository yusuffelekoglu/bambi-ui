{
  "name": "bambi-ui",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:docs": "turbo build --filter=docs...",
    "build:storybook": "turbo build --filter=storybook..."
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.19",
    "typescript": "5.9.2",
    "wrangler": "^4.75.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
