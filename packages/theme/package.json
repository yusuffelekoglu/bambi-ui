{
  "name": "@bambi-ui/theme",
  "version": "0.0.6",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "files": [
    "dist",
    "src/tokens.css"
  ]
}
