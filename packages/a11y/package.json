{
  "name": "@bambi-ui/a11y",
  "version": "0.0.11",
  "description": "Accessibility primitives for bambi-ui — focus management, keyboard interaction, live regions, and WCAG-compliant React utilities",
  "keywords": [
    "bambi-ui",
    "react",
    "accessibility",
    "a11y",
    "wcag",
    "aria",
    "focus-trap",
    "focus-ring",
    "keyboard",
    "live-region",
    "typescript"
  ],
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusuffelekoglu/bambi-ui.git",
    "directory": "packages/a11y"
  },
  "homepage": "https://github.com/yusuffelekoglu/bambi-ui/tree/main/packages/a11y#readme",
  "bugs": {
    "url": "https://github.com/yusuffelekoglu/bambi-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "files": [
    "dist"
  ]
}
