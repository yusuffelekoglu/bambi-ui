{
  "name": "@bambi-ui/typography",
  "version": "0.0.11",
  "description": "Accessible, themeable typography components for bambi-ui — Heading (h1–h6) and Text (body, lead, small, muted, label)",
  "keywords": [
    "bambi-ui",
    "react",
    "typography",
    "heading",
    "text",
    "accessibility",
    "a11y",
    "wcag",
    "component",
    "ui",
    "typescript"
  ],
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusuffelekoglu/bambi-ui.git",
    "directory": "packages/typography"
  },
  "homepage": "https://github.com/yusuffelekoglu/bambi-ui/tree/main/packages/typography#readme",
  "bugs": {
    "url": "https://github.com/yusuffelekoglu/bambi-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --clean --inject-style",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@bambi-ui/theme": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "files": [
    "dist"
  ]
}
